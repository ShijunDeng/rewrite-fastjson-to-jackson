<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>com.huawei.clouds.openrewrite</groupId>
  <artifactId>openrewrite-migration-recipes</artifactId>
  <version>1.0.0-SNAPSHOT</version>
  <packaging>pom</packaging>
  <name>OpenRewrite Migration Recipes</name>
  <description>A multi-module collection of OpenRewrite software migration recipes.</description>
  <url>https://github.com/ShijunDeng/openrewrite-migration-recipes</url>

  <licenses>
    <license>
      <name>Apache License, Version 2.0</name>
      <url>https://www.apache.org/licenses/LICENSE-2.0.txt</url>
    </license>
  </licenses>

  <properties>
    <maven.compiler.release>17</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <rewrite.version>8.87.6</rewrite.version>
    <rewrite.java.dependencies.version>1.59.0</rewrite.java.dependencies.version>
    <jackson.version>2.22.1</jackson.version>
    <fastjson.version>1.2.83</fastjson.version>
    <fastjson2.version>2.0.62</fastjson2.version>
    <junit.version>5.14.2</junit.version>
  </properties>

