    <module>rewrite-hibernate-core-upgrade</module>
    <module>rewrite-vue-router-upgrade</module>
    <module>rewrite-okhttp-upgrade</module>
    <module>rewrite-d3-upgrade</module>
    <module>rewrite-vue-i18n-upgrade</module>
    <module>rewrite-kafka-clients-upgrade</module>
    <module>rewrite-jakarta-servlet-api-upgrade</module>
    <module>rewrite-mybatis-spring-upgrade</module>
    <module>rewrite-marked-upgrade</module>
    <module>rewrite-ngx-echarts-upgrade</module>
    <module>rewrite-flyway-core-upgrade</module>
    <module>rewrite-date-fns-upgrade</module>
    <module>rewrite-uuid-upgrade</module>
    <module>rewrite-shedlock-spring-upgrade</module>
    <module>rewrite-ng-dynamic-forms-core-upgrade</module>
    <module>rewrite-tweenjs-upgrade</module>
    <module>rewrite-mssql-jdbc-upgrade</module>
